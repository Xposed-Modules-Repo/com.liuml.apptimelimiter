<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AppTimeLimiter" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">#F7F8FC</item>
        <item name="android:navigationBarColor">#F7F8FC</item>
    </style>

    <style name="Theme.AppTimeLimiter.BreakPage" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowBackground">#090909</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:statusBarColor">#090909</item>
        <item name="android:navigationBarColor">#090909</item>
        <item name="android:colorAccent">#FFFFFF</item>
    </style>
</resources>
